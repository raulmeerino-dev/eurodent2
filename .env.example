# Base de datos
DATABASE_URL=postgresql+asyncpg://eurodent:password@localhost:5432/eurodent2
DB_PASSWORD=eurodent_dev_pass
DB_ENCRYPTION_KEY=clave-de-cifrado-pgcrypto-aqui-minimo-32-chars

# Auth
JWT_SECRET_KEY=clave-secreta-jwt-muy-larga-cambiar-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=240
REFRESH_TOKEN_EXPIRE_DAYS=7
VERIFACTU_MODE=no_verifactu
SIF_CODIGO=EURODENT2-COPY
SIF_VERSION=0.2.0

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,::1,test
SQL_ECHO=false

# Seguridad
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_BLOCK_SECONDS=900
UPLOAD_RATE_LIMIT_PER_MINUTE=30
MAX_UPLOAD_SIZE_MB=50

# Backups
BACKUP_PATH=/var/backups/eurodent2
BACKUP_GPG_RECIPIENT=admin@clinica.local

# Entorno
ENVIRONMENT=development
